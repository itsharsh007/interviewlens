# Groq — get an API key at https://console.groq.com/keys
GROQ_API_KEY=
# Optional model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Server (production only): comma-separated allowed client origins for CORS.
# e.g. https://your-app.vercel.app,http://localhost:5173
# CLIENT_ORIGIN=

# Client: URL of the deployed server (default: http://localhost:3001)
# VITE_SERVER_URL=https://your-server.onrender.com

# Firebase — copy these from your Firebase project console:
# Project Settings → General → Your apps → Web app → SDK config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
